'output Relay1Off
'output Relay2On
'output Relay2Off
'output Relay3On
'output Relay3Off
'output Relay4On
'output Relay4Off
'output Relay5On
'output Relay5Off
'output Relay6On
'output Relay6Off
'output Relay7Off
'output Relay8Off


'i2c --------------------------------------------------------------------------
