SSPADD.1=1
SSPADD.2=0
SSPADD.3=0
SSPADD.4=0
SSPADD.5=1
SSPADD.6=1
SSPCON1=%00101000 'turn on MSSP and set for master mode i2c 

'uart--------------------------------------------------------------------------
low RS485_mode
'BAUDCON1 = %01001000
BAUDCON1.5=0 'receive data is not inverted
BAUDCON1.3=1 'BRG16=1
BAUDCON1.4=0 'idle state for Txd is 1
SPBRGH1 = 0  '115200 baud
SPBRG1 = 86
RCSTA1 = %00010000
TXSTA1 = %00000100

Mod_ID0                     var     byte
Mod_ID1                     var     byte
Mod_ID2                     var     byte
Mod_ID3                     var     byte
Mod_NE                      var     byte        'N->New module,E->Existing module

'Variables

test_bit                    var     bit
x                           var     byte
y                           var     byte
z                           var     byte
q                           var     byte
s                           var     byte
u                           var     byte
r                           var     byte
w                           var     byte
t                           var     byte
j                           var     byte
